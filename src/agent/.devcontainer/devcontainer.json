{
    "name": "AI Agent Development Container",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/agent:1": {
            "claudeCodeVersion": "latest",
            "installCodex": true,
            "installNode": true,
            "installPython": true
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropics.claude-dev"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            }
        }
    },
    "remoteEnv": {
        "SHENGSUANYUN_API_KEY": "${localEnv:SHENGSUANYUN_API_KEY}",
        "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
        "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
        "OPENAI_BASE_URL": "${localEnv:OPENAI_BASE_URL}",
        "ANTHROPIC_BASE_URL": "${localEnv:ANTHROPIC_BASE_URL}"
    },
    "postCreateCommand": "agent-tools-info"
}
