{
    "install_all": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agent": {
                "claudeCodeVersion": "latest",
                "installCodex": true,
                "installNode": true,
                "installPython": true
            }
        }
    },
    "claude_only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agent": {
                "claudeCodeVersion": "latest",
                "installCodex": false
            }
        }
    },
    "codex_only": {
        "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
        "features": {
            "agent": {
                "claudeCodeVersion": "none",
                "installCodex": true
            }
        }
    }
}
